# Copy to inventory/group_vars/all and fill in your values.
# Do not commit inventory/group_vars/all (it may contain secrets).

ansible_user: ubuntu
ansible_ssh_private_key_file: ~/.ssh/your-key.pem

ansible_python_interpreter: /usr/bin/python3

# Keyring and seed (set for your network)
# keyring_password: ""
# seed_host: "node.example.com"

# RPC and dashboard URLs (defaults work for the public Gonka network)
rpc_server_url_1: "http://node1.gonka.ai:26657"
rpc_server_url_2: "http://node2.gonka.ai:26657"
dashboard_url: "http://node3.gonka.ai:8000"
tracker_url: "https://tracker.gonka.hyperfusion.io"

# Optional: Telegram notifications for network check playbook
# Get bot token from @BotFather, chat_id from https://api.telegram.org/bot<TOKEN>/getUpdates
# telegram_bot_token: ""
# telegram_chat_id: ""
